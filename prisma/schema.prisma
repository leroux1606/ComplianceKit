generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  companyAddress String?
  companyEmail   String?
  companyName    String?
  dpoEmail       String?
  dpoName        String?
  anonymizedAt   DateTime?
  deletedAt      DateTime?
  deletionReason String?
  ageVerifiedAt  DateTime?
  consentedAt    DateTime?
  dpaAcceptedAt  DateTime?
  apiKey           String?   @unique
  accounts         Account[]
  sessions         Session[]
  subscription     Subscription?
  websites         Website[]
  ownedTeam        TeamMember[] @relation("OwnedTeam")
  teamMemberships  TeamMember[] @relation("TeamMemberships")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Website {
  id             String               @id @default(cuid())
  userId         String
  name           String
  url            String
  description    String?
  status         String               @default("active")
  embedCode      String?              @unique
  lastScanAt          DateTime?
  lastScanStatus      String?
  scanSchedule        String    @default("none")
  nextScheduledScanAt DateTime?
  companyName    String?
  companyAddress String?
  companyEmail   String?
  dpoName        String?
  dpoEmail       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  bannerConfig   BannerConfig?
  consents       Consent[]
  dsarRequests   DataSubjectRequest[]
  policies       Policy[]
  scans          Scan[]
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("websites")
}

model Scan {
  id          String    @id @default(cuid())
  websiteId   String
  status      String    @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  score       Int?
  ccpaScore   Int?
  createdAt   DateTime  @default(now())
  cookies     Cookie[]
  findings    Finding[]
  website     Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  scripts     Script[]

  @@index([websiteId])
  @@index([status])
  @@map("scans")
}

model Cookie {
  id          String    @id @default(cuid())
  scanId      String
  name        String
  domain      String
  path        String    @default("/")
  secure      Boolean   @default(false)
  httpOnly    Boolean   @default(false)
  sameSite    String?
  expires     DateTime?
  category    String?
  description String?
  createdAt   DateTime  @default(now())
  scan        Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("cookies")
}

model Script {
  id         String   @id @default(cuid())
  scanId     String
  url        String?
  content    String?
  type       String
  category   String?
  name       String?
  detectedAt DateTime @default(now())
  scan       Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("scripts")
}

model Finding {
  id             String   @id @default(cuid())
  scanId         String
  type           String
  severity       String
  title          String
  description    String
  recommendation String?
  createdAt      DateTime @default(now())
  scan           Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("findings")
}

model BannerConfig {
  id                       String   @id @default(cuid())
  websiteId                String   @unique
  theme                    String   @default("light")
  position                 String   @default("bottom")
  primaryColor             String   @default("#0f172a")
  textColor                String   @default("#ffffff")
  buttonStyle              String   @default("rounded")
  animation                String   @default("slide")
  customCss                String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  cookiePolicyUrl          String?
  privacyPolicyUrl         String?
  consentModeV2            Boolean  @default(true)
  withdrawalButtonPosition String   @default("bottom-right")
  website                  Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("banner_configs")
}

model Consent {
  id                  String   @id @default(cuid())
  websiteId           String
  visitorId           String
  preferences         Json
  ipAddress           String?
  userAgent           String?
  consentedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt
  bannerConfigVersion String?
  consentMethod       String   @default("unknown")
  policyVersion       Int?
  website             Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([visitorId])
  @@index([websiteId, consentedAt])
  @@map("consents")
}

model Policy {
  id          String   @id @default(cuid())
  websiteId   String
  type        String
  language    String   @default("en")
  content     String
  htmlContent String?
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([websiteId, type, isActive])
  @@map("policies")
}

model PolicyTemplate {
  id        String   @id @default(cuid())
  type      String
  language  String
  content   String
  variables Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, language, isDefault])
  @@map("policy_templates")
}

model Plan {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  paystackPlanCode String   @unique
  price            Decimal  @db.Decimal(10, 2)
  currency         String   @default("ZAR")
  interval         String   @default("monthly")
  maxWebsites      Int?
  features         Json
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("plans")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  planId               String
  paystackPlanCode     String
  paystackSubCode      String?
  paystackCustomerCode String?
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  invoices             Invoice[]
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  paystackRef    String?
  amount         Decimal      @db.Decimal(10, 2)
  currency       String       @default("ZAR")
  status         String
  paidAt         DateTime?
  dueDate        DateTime
  pdfUrl         String?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model DataSubjectRequest {
  id                String           @id @default(cuid())
  websiteId         String
  requestType       String
  status            String           @default("pending")
  priority          String           @default("normal")
  requesterEmail    String
  requesterName     String?
  requesterPhone    String?
  description       String
  additionalInfo    String?
  verificationToken String           @unique @default(cuid())
  verifiedAt        DateTime?
  assignedTo        String?
  internalNotes     String?
  responseContent   String?
  dueDate           DateTime
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  website           Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  activities        DsarActivity[]
  attachments       DsarAttachment[]

  @@index([websiteId])
  @@index([status])
  @@index([requesterEmail])
  @@index([verificationToken])
  @@map("data_subject_requests")
}

model DsarActivity {
  id          String             @id @default(cuid())
  dsarId      String
  action      String
  description String
  performedBy String?
  metadata    Json?
  createdAt   DateTime           @default(now())
  dsar        DataSubjectRequest @relation(fields: [dsarId], references: [id], onDelete: Cascade)

  @@index([dsarId])
  @@map("dsar_activities")
}

model DsarAttachment {
  id         String             @id @default(cuid())
  dsarId     String
  filename   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime           @default(now())
  dsar       DataSubjectRequest @relation(fields: [dsarId], references: [id], onDelete: Cascade)

  @@index([dsarId])
  @@map("dsar_attachments")
}

model TeamMember {
  id          String    @id @default(cuid())
  ownerId     String
  userId      String?
  email       String
  role        String    @default("viewer")
  status      String    @default("pending")
  inviteToken String    @unique @default(cuid())
  invitedAt   DateTime  @default(now())
  acceptedAt  DateTime?
  owner       User      @relation("OwnedTeam", fields: [ownerId], references: [id], onDelete: Cascade)
  user        User?     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([ownerId, email])
  @@index([ownerId])
  @@index([userId])
  @@index([inviteToken])
  @@map("team_members")
}

model RateLimitRecord {
  id      String   @id @default(cuid())
  key     String   @unique
  count   Int      @default(1)
  resetAt DateTime

  @@index([key])
  @@index([resetAt])
  @@map("rate_limit_records")
}

model LoginAttemptRecord {
  id           String    @id @default(cuid())
  identifier   String    @unique
  count        Int       @default(0)
  firstAttempt DateTime
  lastAttempt  DateTime
  lockedUntil  DateTime?

  @@index([identifier])
  @@index([lockedUntil])
  @@map("login_attempt_records")
}
