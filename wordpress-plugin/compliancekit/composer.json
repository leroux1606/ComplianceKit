{
    "name": "compliancekit/compliancekit-wordpress-plugin",
    "description": "ComplianceKit cookie consent WordPress plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6"
    },
    "scripts": {
        "test": "phpunit --bootstrap tests/bootstrap.php tests/"
    },
    "autoload-dev": {
        "psr-4": {
            "ComplianceKit\\Tests\\": "tests/"
        }
    }
}
