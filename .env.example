# Database
#
# LOCAL DEV: set only DATABASE_URL pointing to your local Postgres instance.
#
# PRODUCTION (Neon or Supabase — required before launch):
#   DATABASE_URL  → pooled connection string (goes through PgBouncer)
#                   Neon:     Settings > Connection string > Pooled connection
#                   Supabase: Settings > Database > Connection pooling (port 6543)
#   DIRECT_URL    → direct (non-pooled) connection string
#                   Used by Prisma for migrations only (prisma db push / migrate deploy)
#                   Neon:     Settings > Connection string > Direct connection
#                   Supabase: Settings > Database > Connection string (port 5432)
#
# Why two URLs? PgBouncer runs in transaction mode and cannot handle the
# persistent connections that schema migrations require. Runtime queries go
# through the pooler; migrations bypass it via the direct URL.
DATABASE_URL="postgresql://user:password@localhost:5432/compliancekit?schema=public"
DIRECT_URL=""

# Auth.js v5 (next-auth v5)
# AUTH_SECRET is the primary name in v5 — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Legacy v4 names kept for reference — v5 ignores them
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (Email)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="ComplianceKit <noreply@yourdomain.com>"
NEXT_PUBLIC_SUPPORT_EMAIL="support@yourdomain.com"
#
# SECURITY_ALERT_EMAIL — where critical security event alerts are sent (F2).
# Defaults to NEXT_PUBLIC_SUPPORT_EMAIL if not set.
# Events that trigger an alert: account lockouts, CSRF detected, SQL injection attempt,
# XSS attempt, unauthorised access, rate-limit DB error.
# Set to your personal or ops inbox so alerts arrive immediately.
SECURITY_ALERT_EMAIL="security@yourdomain.com"

# PayStack (ZAR billing — South Africa)
PAYSTACK_SECRET_KEY="your-paystack-secret-key"
PAYSTACK_PUBLIC_KEY="your-paystack-public-key"
PAYSTACK_WEBHOOK_SECRET="your-paystack-webhook-secret"
# Plan codes from PayStack dashboard
PAYSTACK_STARTER_PLAN_CODE="PLN_starter"
PAYSTACK_PROFESSIONAL_PLAN_CODE="PLN_professional"
PAYSTACK_ENTERPRISE_PLAN_CODE="PLN_enterprise"

# Stripe (USD billing — International)
# Create prices in Stripe dashboard: https://dashboard.stripe.com/products
# These are the recurring price IDs for each plan (price_...)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PROFESSIONAL_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Admin
# Comma-separated list of email addresses that can access /admin
ADMIN_EMAILS="you@yourdomain.com"

# App URL (for widgets)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Jobs
#
# CRON_SECRET secures the daily cron endpoints so only Vercel (or you) can trigger them.
# Both cron jobs use this:
#   - /api/cron/process-account-deletions  (runs 02:00 UTC daily)
#   - /api/cron/archive-consent            (runs 03:00 UTC daily)
#
# Generate a value with:
#   openssl rand -base64 32
#
# Add this to Vercel environment variables before deploying.
# Without it, both cron jobs will refuse to run (500 error).
CRON_SECRET=""

# Anthropic / Claude AI (AI-Powered Policy Generation — Professional/Enterprise feature)
#
# Required for the "AI Policy" button on the Policies page.
# Get your API key at: https://console.anthropic.com/
# The feature degrades gracefully: if this key is missing, AI generation returns an error
# and users see a message to configure the key. Template-based generation always works.
ANTHROPIC_API_KEY=""

# Sentry (Error Tracking — F1)
#
# Create a project at https://sentry.io, then copy the DSN from:
#   Project Settings > Client Keys (DSN)
#
# NEXT_PUBLIC_ prefix is required — the client-side Sentry init reads this at runtime.
# Source maps are uploaded at build time using SENTRY_AUTH_TOKEN (set in Vercel only).
#
# To generate an auth token: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:read, project:releases, org:read
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
