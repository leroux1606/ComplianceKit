# E2E Test Environment
# Copy to .env.test and fill in values before running: npx playwright test

# ── Database ─────────────────────────────────────────────────────────────────
# Use a SEPARATE test database — the E2E suite writes real records.
DATABASE_URL="postgresql://user:password@localhost:5432/compliancekit_test?schema=public"
DIRECT_URL=""

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET="test-secret-at-least-32-characters-longXXXXXXXXXXXX"
AUTH_URL="http://localhost:3000"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Not needed for E2E (tests use credentials auth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave blank — dev mode prints emails to terminal instead of sending them
RESEND_API_KEY=""
EMAIL_FROM="ComplianceKit <noreply@localhost>"
NEXT_PUBLIC_SUPPORT_EMAIL="support@localhost"
SECURITY_ALERT_EMAIL=""

# ── PayStack (ZAR) ───────────────────────────────────────────────────────────
# Use PayStack test keys for billing tests
# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_WEBHOOK_SECRET=""
PAYSTACK_STARTER_PLAN_CODE=""
PAYSTACK_PROFESSIONAL_PLAN_CODE=""
PAYSTACK_ENTERPRISE_PLAN_CODE=""

# ── Stripe (USD) ─────────────────────────────────────────────────────────────
# Use Stripe test keys for billing tests
# Test card: 4242 4242 4242 4242 | Any future date | Any CVC
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test_..."
STRIPE_STARTER_PRICE_ID="price_test_..."
STRIPE_PROFESSIONAL_PRICE_ID="price_test_..."
STRIPE_ENTERPRISE_PRICE_ID="price_test_..."

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS="e2e@test.local"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="test-cron-secret-not-used-in-e2e"

# ── Optional features ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# ── E2E test credentials ─────────────────────────────────────────────────────
# The global-setup will create this account on first run (or sign in if it exists)
E2E_TEST_EMAIL="e2e@test.local"
E2E_TEST_PASSWORD="E2eTest123!"
E2E_TEST_NAME="E2E Test User"
